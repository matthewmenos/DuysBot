# ══════════════════════════════════════════════════════════════════════════════
# DUYS Trading Bot — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Generate the encryption key FIRST:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Never commit .env to git. Back up your ENCRYPTION_KEY separately.
# ══════════════════════════════════════════════════════════════════════════════

# ── Security ──────────────────────────────────────────────────────────────────
# Fernet AES-256 key — used to encrypt all stored API keys and DB backups.
# Changing this after first run will make existing keys unreadable.
# Required — bot refuses to start if this is not set.
ENCRYPTION_KEY=your_generated_fernet_key_here

# Secret salt used to generate per-user TradingView webhook tokens.
# Set to any random string (min 32 hex chars). If unset, a random value is
# generated each restart, which invalidates all existing webhook tokens.
#   python3 -c "import secrets; print(secrets.token_hex(32))"
TV_WEBHOOK_SECRET_SALT=your_generated_hex_salt_here

# Set to 1 once you have an nginx/Caddy TLS reverse proxy in front of the bot.
# Suppresses the startup warning about plain HTTP webhooks.
BEHIND_TLS_PROXY=

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram.
BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated Telegram user IDs with admin access.
# Find your ID by messaging @userinfobot on Telegram.
ADMIN_IDS=123456789,987654321

# Private Telegram channel/group ID for support messages (bot must be admin).
# Leave blank to disable in-bot support forwarding.
SUPPORT_CHANNEL_ID=-1001234567890

# ── Paystack (card / mobile money / bank transfer) ────────────────────────────
# Get keys from: dashboard.paystack.com → Settings → API Keys & Webhooks
# Use sk_test_ / pk_test_ for testing, sk_live_ / pk_live_ for production.
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here

# Webhook secret — copy from Paystack dashboard after setting webhook URL.
# Webhook URL to register: https://yourdomain.com/paystack/webhook
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret_here

# Public HTTPS URL of your server (used for Paystack callback and webhook registration).
BOT_WEBHOOK_URL=https://yourdomain.com

# Port the internal HTTP server listens on for Paystack webhooks.
# TradingView webhook server runs on WEBHOOK_PORT + 1.
WEBHOOK_PORT=8080

# ── Subscription Pricing (USD) ────────────────────────────────────────────────
# These prices are shown to users and charged via Paystack / USDT crypto.
# Changing them takes effect immediately — no code change required.
PLAN_PRICE_1M=12.00
PLAN_PRICE_3M=34.00
PLAN_PRICE_6M=65.00

# ── Free Trial & Referral Rewards ─────────────────────────────────────────────
# Number of free trial days given to new users (once per account lifetime).
FREE_TRIAL_DAYS=7

# Months of free access awarded to a referrer when their referred user subscribes.
REFERRAL_REWARD_MONTHS=1

# ── Crypto Payment — USDT wallet addresses ────────────────────────────────────
# Set wallet addresses for each network you want to accept.
# Leave a network's address blank to hide it from the payment menu.

# Aptos — USDT (LayerZero bridged). No API key required.
USDT_APTOS_ADDRESS=0xYourAptosWalletAddressHere

# TRON — USDT TRC-20. Free API key at: trongrid.io
USDT_TRON_ADDRESS=TYourTronWalletAddressHere
TRONGRID_API_KEY=your_trongrid_api_key_here

# BNB Smart Chain — USDT BEP-20. Free API key at: bscscan.com/apis
USDT_BSC_ADDRESS=0xYourBscWalletAddressHere
BSCSCAN_API_KEY=your_bscscan_api_key_here

# ── Exchange API Keys ──────────────────────────────────────────────────────────
# All exchange keys are optional — users enter their own keys via the bot.
# Set these to pre-configure a default account, or leave blank.

# Binance — standard key + secret
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Bybit — standard key + secret
BYBIT_API_KEY=
BYBIT_API_SECRET=

# OKX — requires passphrase in addition to key + secret
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# MEXC — standard key + secret (keys expire 90 days after creation; bot warns automatically)
MEXC_API_KEY=
MEXC_API_SECRET=

# KuCoin — requires passphrase in addition to key + secret
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=

# Coinbase Advanced Trade — standard key + secret
# Create at: coinbase.com → Settings → API → New API Key
# Required permissions: View + Trade
COINBASE_API_KEY=
COINBASE_API_SECRET=

# BingX — standard key + secret
# Create at: bingx.com → Account → API Management
# Required permissions: Read + Spot Trade
BINGX_API_KEY=
BINGX_API_SECRET=

# Gate.io — standard key + secret
# Create at: gate.io → Account → API Management
# Required permissions: Read only + Spot Trade
GATEIO_API_KEY=
GATEIO_API_SECRET=

# ── Arbitrage Engine Tuning ────────────────────────────────────────────────────
# Minimum net profit % (after ALL fees) required to flag an arb opportunity.
ARB_MIN_PROFIT_PCT=0.3

# Flat withdrawal/transfer cost (USDT) assumed per cross-exchange leg.
ARB_WITHDRAWAL_FEE_USDT=1.5

# Per-exchange taker fees (fraction: 0.001 = 0.10%).
# Override these if your account tier qualifies for lower fees.
ARB_FEE_BINANCE=0.001
ARB_FEE_BYBIT=0.001
ARB_FEE_OKX=0.001
ARB_FEE_MEXC=0.002
ARB_FEE_KUCOIN=0.001
ARB_FEE_COINBASE=0.006
ARB_FEE_BINGX=0.001
ARB_FEE_GATEIO=0.002
ARB_FEE_DEFAULT=0.001

# ── Circuit Breaker ────────────────────────────────────────────────────────────
# Halt all new auto-trades for a user if their daily PnL drops below this %.
# Set to 0 to disable. Example: 5.0 = halt after -5% drawdown in a day.
MAX_DAILY_LOSS_PCT=5.0

# ── Feature Limits ────────────────────────────────────────────────────────────
MAX_DCA_PLANS=3
MAX_GRID_PLANS=2
MAX_SMART_ORDERS=5

# Correlation threshold (0–1). Pairs with correlation above this are blocked
# from being held simultaneously to prevent doubling exposure.
CORRELATION_THRESHOLD=0.85

# ── Signal & Market Data APIs (all optional) ──────────────────────────────────
# Bot degrades gracefully when these are missing — only technical indicators
# (RSI, EMA, MACD, Bollinger Bands, volume) are used.

# CryptoCompare — news sentiment scoring. Free tier: cryptocompare.com/api
CRYPTOCOMPARE_API_KEY=

# CoinMarketCap — rank, 24h/7d change, market cap signal layer. Free basic plan: coinmarketcap.com/api
COINMARKETCAP_API_KEY=

# NewsAPI — general crypto news headlines. Free tier: newsapi.org
NEWSAPI_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file. Created automatically on first run.
# Use an absolute path on production servers (e.g. /home/ubuntu/duysbot/bot_data.db).
DB_PATH=bot_data.db

# Path to the PTB PicklePersistence file.
# Stores in-progress wizard state, signal cooldowns, and arb fingerprints so
# they survive bot restarts. Created automatically.
PERSISTENCE_FILE=bot_persistence.pickle

# Default paper-trading balance for new users (USDT).
PAPER_DEFAULT_BALANCE=1000.0
